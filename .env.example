# ──────────────────────────────────────────────────────────────────────────────
# Environment variables — copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
# The public domain name for your deployment (used by Nginx + Certbot)
DOMAIN=yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=saymed
POSTGRES_USER=saymed
POSTGRES_PASSWORD=changeme_strong_password

# Full connection string consumed by the backend (Kysely / pg)
# When running inside Docker Compose, the host is the service name "db"
DATABASE_URL=postgres://saymed:changeme_strong_password@db:5432/saymed

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_strong_redis_password

# Full connection URL consumed by the backend (ioredis)
REDIS_URL=redis://:changeme_strong_redis_password@redis:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── AI Services ───────────────────────────────────────────────────────────────
# Google Gemini API key (https://ai.google.dev/)
GEMINI_API_KEY=your_gemini_api_key_here

# WhisperX microservice URL (deployed separately, e.g. Modal)
WHISPERX_API_URL=https://your-whisperx-endpoint.modal.run

# ── Backend ───────────────────────────────────────────────────────────────────
# Allowed CORS origins (comma-separated if multiple)
CORS_ORIGINS=https://yourdomain.com

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────────────────────
# Baked into the Vite bundle at build time — must point to the public API URL
VITE_API_BASE=https://yourdomain.com/api

# ── Certbot / Let's Encrypt ───────────────────────────────────────────────────
# Email address for expiry notifications (used in certbot certonly command)
# CERTBOT_EMAIL=you@yourdomain.com

# ── No-TLS / pre-domain deployment (docker-compose.prod-no-tls.yml) ──────────
# Use these values instead of the domain-based ones above when deploying before
# you have a domain name.  DOMAIN is not read by the no-TLS compose file.
#
# VITE_API_BASE=http://<SERVER_IP>/api
# CORS_ORIGINS=http://<SERVER_IP>
