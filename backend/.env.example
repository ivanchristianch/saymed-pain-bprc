# ──────────────────────────────────────────────────────────────────────────────
# Local development only (outside Docker).
# Copy to backend/.env and fill in values when running `npm run dev` directly.
#
# When using Docker Compose (dev or prod), this file is NOT used — environment
# variables are injected from the root .env file via `env_file: .env`.
# See root .env.example for the full canonical reference.
# ──────────────────────────────────────────────────────────────────────────────

# App Config
APP_ENV=local
APP_NAME="SayMed Pain BPRC API"

# Auth
JWT_SECRET=CHANGE_ME_SUPER_SECRET
JWT_ALG=HS256
ACCESS_TOKEN_MINUTES=720

# Database (localhost because you're running outside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saymed

# CORS
CORS_ORIGINS=http://localhost:3000

# AI Services
GEMINI_API_KEY=
WHISPERX_API_URL=

# Redis (localhost because you're running outside Docker)
REDIS_URL=redis://localhost:6379

# Pino log level
LOG_LEVEL=debug
